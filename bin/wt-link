#!/usr/bin/env bash
# wt-link — Mount or unmount a git worktree as a fully functional local Herd site.
#
# OVERVIEW
#   When developing on a feature branch using a git worktree, this script wires
#   up all the pieces that make the worktree browsable at the same local URL as
#   the canonical (main) site:
#
#     • Downloads WordPress core (version from setup.json)
#     • Copies wp-config.php from the canonical site
#     • Symlinks git-untracked plugins and uploads from the canonical site
#     • Installs JS deps in each Eightshift package via auto-detected PM
#     • Symlinks composer vendor/ from canonical (falls back to composer install)
#     • Builds JS/CSS assets via the package's package manager
#     • Runs `herd link <site-name>` to point the local domain here
#
#   On `unmount` every symlink is removed, WP core files are deleted, and
#   `herd unlink` restores the canonical site.
#
# USAGE
#   wt-link mount              Set up current worktree as the local dev site
#   wt-link mount --hard-copy  Same but hard-copy untracked plugins (parallel cp -Rl)
#   wt-link unmount            Tear it down and restore the canonical site
#   wt-link status             Show what is linked / installed
#   wt-link mount --cwd PATH   Mount a specific worktree directory
#
# REQUIREMENTS
#   wp-cli, herd, composer, jq
#   Node package manager: bun, npm, yarn, or pnpm (auto-detected per package)
#
# CONFIGURATION (optional — auto-detected from setup.json when omitted)
#   CANONICAL_SITE   Absolute path to the canonical (main) site.
#                    Default: ~/Sites/<site-name> where <site-name> is
#                    extracted from setup.json urls.local.

# shellcheck disable=SC2034  # colour vars used via echo -e

set -euo pipefail

WT_LINK_VERSION="2.7.1"

# ──────────────────────────────────────────────────────────────────────────────
# COLOURS
# ──────────────────────────────────────────────────────────────────────────────

BOLD="\033[1m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
CYAN="\033[0;36m"
RESET="\033[0m"

# ──────────────────────────────────────────────────────────────────────────────
# LIB_DIR RESOLUTION
# ──────────────────────────────────────────────────────────────────────────────

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 1. Dev / extracted tarball layout: bin/ is sibling of lib/
if [[ -d "$_script_dir/../lib/wt-link" ]]; then
    LIB_DIR="$(cd "$_script_dir/../lib/wt-link" && pwd)"
# 2. Homebrew Cellar layout: bin/ is sibling of libexec/
elif [[ -d "$_script_dir/../libexec/lib/wt-link" ]]; then
    LIB_DIR="$(cd "$_script_dir/../libexec/lib/wt-link" && pwd)"
else
    echo "wt-link: cannot find lib/wt-link — installation may be broken" >&2
    exit 1
fi

# Source modules in dependency order (ui.sh must be first)
# shellcheck source=../lib/wt-link/ui.sh
source "$LIB_DIR/ui.sh"
# shellcheck source=../lib/wt-link/utils.sh
source "$LIB_DIR/utils.sh"
# shellcheck source=../lib/wt-link/project.sh
source "$LIB_DIR/project.sh"
# shellcheck source=../lib/wt-link/state.sh
source "$LIB_DIR/state.sh"
# shellcheck source=../lib/wt-link/runtime.sh
source "$LIB_DIR/runtime.sh"
# shellcheck source=../lib/wt-link/mount.sh
source "$LIB_DIR/mount.sh"
# shellcheck source=../lib/wt-link/unmount.sh
source "$LIB_DIR/unmount.sh"
# shellcheck source=../lib/wt-link/status.sh
source "$LIB_DIR/status.sh"
# shellcheck source=../lib/wt-link/rebuild.sh
source "$LIB_DIR/rebuild.sh"
# shellcheck source=../lib/wt-link/list.sh
source "$LIB_DIR/list.sh"

# ──────────────────────────────────────────────────────────────────────────────
# ARGUMENT PARSING
# ──────────────────────────────────────────────────────────────────────────────

# REGISTRY_DIR is user-global and needed by list/starship before project resolution
REGISTRY_DIR="$HOME/.config/wt-link"

# Show help / version / starship / list before any project resolution
case "${1:-help}" in
    help|--help|-h)
        echo "Usage: wt-link <command> [--cwd PATH]"
        echo ""
        echo "Commands:"
        echo "  mount             Set up a git worktree as a fully working local Herd site"
        echo "  unmount           Tear down and restore the canonical site"
        echo "  status            Show current link status"
        echo "  rebuild-composer                   Delete vendor/ + vendor-prefixed/ and re-run composer install (themes)"
        echo "  rebuild-composer --plugins         Same but targets plugins instead of themes"
        echo "  rebuild-composer --all             Same but targets both themes and plugins"
        echo "  rebuild-node                       Start the webpack watcher for the first theme"
        echo "  rebuild-node --plugins             Start the webpack watcher for the first plugin"
        echo "  rebuild-node --build               Full JS/CSS rebuild for themes (deletes node_modules/ + public/)"
        echo "  rebuild-node --build --plugins     Same but targets plugins instead of themes"
        echo "  rebuild-node --build --all         Same but targets both themes and plugins"
        echo "  starship                           Output ⛓ if cwd is a mounted worktree (for Starship prompt)"
        echo ""
        echo "Options:"
        echo "  --cwd PATH    Run against a specific worktree directory (default: current directory)"
        echo "  --hard-copy   Hard-copy untracked plugins instead of symlinking (parallel cp -Rl)"
        echo "  --plugins     Target plugin eightshift packages instead of themes"
        echo "  --all         Target both theme and plugin eightshift packages"
        echo ""
        echo "Short aliases (fish):"
        echo "  wlm    wt-link mount"
        echo "  wlu    wt-link unmount"
        echo "  wls    wt-link status"
        echo "  wlrc   wt-link rebuild-composer"
        echo "  wlrn   wt-link rebuild-node"
        echo "  wlrb   wt-link rebuild-node --build"
        echo "  wlrnp  wt-link rebuild-node --plugins"
        echo "  wlrbp  wt-link rebuild-node --build --plugins"
        echo ""
        echo "Environment:"
        echo "  CANONICAL_SITE   Override the canonical site path (default: ~/Sites/<site-name>)"
        echo ""
        echo "Examples:"
        echo "  wt-link mount"
        echo "  wt-link mount --cwd ~/Sites/myproject.feature-branch"
        echo "  CANONICAL_SITE=~/Sites/myproject wt-link mount"
        echo "  wt-link mount --hard-copy"
        echo "  wt-link unmount"
        echo "  wt-link status"
        exit 0
        ;;
    --version|-v)
        echo "wt-link $WT_LINK_VERSION"
        exit 0
        ;;
    starship)
        cmd_starship
        exit 0
        ;;
    list)
        cmd_list
        exit 0
        ;;
esac

EXPLICIT_CWD=""
FILTERED_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --cwd)
            [[ -n "${2:-}" ]] || error "--cwd requires a path argument"
            EXPLICIT_CWD="$2"
            shift 2
            ;;
        --cwd=*)
            EXPLICIT_CWD="${1#--cwd=}"
            shift
            ;;
        *)
            FILTERED_ARGS+=("$1")
            shift
            ;;
    esac
done
set -- "${FILTERED_ARGS[@]+"${FILTERED_ARGS[@]}"}"

# ──────────────────────────────────────────────────────────────────────────────
# PROJECT RESOLUTION
# ──────────────────────────────────────────────────────────────────────────────

if [[ -n "$EXPLICIT_CWD" ]]; then
    START_DIR="$(cd "$EXPLICIT_CWD" && pwd)" || error "Directory not found: $EXPLICIT_CWD"
else
    START_DIR="$(pwd)"
fi

# Gracefully skip non-WP projects (no error — safe to call unconditionally)
if ! WORKTREE_ROOT="$(find_project_root "$START_DIR")"; then
    warn "Not a WordPress project (setup.json not found in $START_DIR or any parent directory up to git root) — skipping"
    exit 0
fi

SETUP_JSON="$WORKTREE_ROOT/setup.json"

# Extract local URL from setup.json (e.g. "https://infobip.test/")
LOCAL_URL="$(jq -r '.urls.local // empty' "$SETUP_JSON" 2>/dev/null || true)"
[[ -n "$LOCAL_URL" ]] || error "Could not read urls.local from setup.json"

# Derive site name: strip scheme, trailing slash, and .test/.local/.dev TLD
# e.g. "https://infobip.test/" -> "infobip"
SITE_NAME="$(echo "$LOCAL_URL" | sed -E 's|^https?://||; s|/.*||' | sed -E 's/\.(test|local|dev)$//')"

# WP version from setup.json
WP_VERSION="$(jq -r '.core // "latest"' "$SETUP_JSON" 2>/dev/null || echo "latest")"

# Subdomains for WPML or multisite (optional — space-separated for array handoff)
SUBDOMAIN_LIST="$(jq -r '(.urls.subdomains // []) | join(" ")' "$SETUP_JSON" 2>/dev/null || true)"

# Canonical site path (override with env var)
CANONICAL_SITE="${CANONICAL_SITE:-$HOME/Sites/$SITE_NAME}"

WP_CONTENT="$WORKTREE_ROOT/wp-content"
CANONICAL_WP_CONTENT="$CANONICAL_SITE/wp-content"

# ──────────────────────────────────────────────────────────────────────────────
# STATE & REGISTRY PATH CONSTANTS
# ──────────────────────────────────────────────────────────────────────────────

WP_CORE_MARKER="$WORKTREE_ROOT/wp-load.php"

# REGISTRY_DIR already set before project resolution (for list/starship); keep assignments here
REGISTRY_FILE="$REGISTRY_DIR/$SITE_NAME.active"
STATE_FILE="$REGISTRY_DIR/$SITE_NAME.$(basename "$WORKTREE_ROOT").state"

# Fall back to legacy state file location (pre-v1.8.0: stored inside the worktree)
# so that existing mounted worktrees keep working before their next mount/migrate cycle
if [[ ! -f "$STATE_FILE" && -f "$WORKTREE_ROOT/.worktree-link-state" ]]; then
    STATE_FILE="$WORKTREE_ROOT/.worktree-link-state"
fi

# ──────────────────────────────────────────────────────────────────────────────
# COMMAND DISPATCH
# ──────────────────────────────────────────────────────────────────────────────

COMMAND="${1:-help}"
shift 2>/dev/null || true

FORCE=0
YES=0
HARD_COPY=0
BUILD=0
PLUGINS=0
ALL=0
for arg in "$@"; do
    [[ "$arg" == "--force" || "$arg" == "-f" ]] && FORCE=1
    [[ "$arg" == "--yes"   || "$arg" == "-y" ]] && YES=1
    [[ "$arg" == "--hard-copy" ]] && HARD_COPY=1
    [[ "$arg" == "--build" ]] && BUILD=1
    [[ "$arg" == "--plugins" ]] && PLUGINS=1
    [[ "$arg" == "--all" ]] && ALL=1
done

case "$COMMAND" in
    mount)            cmd_mount ;;
    unmount)          cmd_unmount ;;
    status)           cmd_status ;;
    list)             cmd_list ;;
    starship)         cmd_starship ;;
    rebuild-composer) cmd_rebuild_composer ;;
    rebuild-node)     cmd_rebuild_node ;;
    *)
        error "Unknown command: $COMMAND. Run 'wt-link --help' for usage."
        ;;
esac
